{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "isbn",
    "amazon_url",
    "author",
    "language",
    "pages",
    "publisher",
    "title",
    "year"
  ],
  "properties": {
    "isbn": {
      "type": "string"
    },
    "amazon_url": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "pages": {
      "type": "integer"
    },
    "publisher": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    }
  }
}
