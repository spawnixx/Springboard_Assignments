{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["author", "language", "pages", "title", "year"],
  "properties": {
    "amazon_url": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "pages": {
      "type": "integer"
    },
    "publisher": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    }
  }
}
